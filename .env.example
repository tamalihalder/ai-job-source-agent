# ── LLM Provider ──────────────────────────────────────────────────────────────
#
# Option A: Anthropic Claude (paid API)
#   Set ANTHROPIC_API_KEY and the agent uses Claude automatically.
#
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-haiku-4-5-20251001   # optional, this is the default
#
# Option B: Ollama (free, local)
#   Leave ANTHROPIC_API_KEY unset (or as the placeholder below).
#   Run: ollama pull llama3 && ollama serve
#
# OLLAMA_MODEL=llama3
